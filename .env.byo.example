# ============================================================================
# Scrapegoat BYO (Bring Your Own) Configuration
# ============================================================================
# This configuration uses external PostgreSQL and embedding services

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Required)
# ----------------------------------------------------------------------------
# PostgreSQL connection URL with pgvector extension
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres.example.com:5432/scrapegoat

# ----------------------------------------------------------------------------
# EMBEDDING API CONFIGURATION (Required)
# ----------------------------------------------------------------------------
# OpenAI-compatible embedding API endpoint
# Must include /v1 suffix for OpenAI-compatible APIs
OPENAI_API_BASE=http://embed.example.com/v1

# API key for embedding service (set to 'not-required' if not needed)
OPENAI_API_KEY=not-required

# Embedding model name (OpenAI-compatible naming)
# Examples:
#   - text-embedding-3-small (OpenAI/compatible services)
#   - text-embedding-3-large (OpenAI)
#   - all-MiniLM-L6-v2 (sentence-transformers via Text-Embeddings-Inference)
DOCS_MCP_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# SERVICE PORTS
# ----------------------------------------------------------------------------
# MCP Server (Model Context Protocol)
MCP_PORT=6280

# Web UI
WEB_PORT=6281

# Worker API (Background processing)
WORKER_PORT=8080

# ----------------------------------------------------------------------------
# CRAWL4AI CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Enable Crawl4AI for enhanced web scraping
CRAWL4AI_ENABLED=true

# Crawl4AI service URL (localhost when using docker-compose)
CRAWL4AI_SERVICE_URL=http://localhost:8001

# Crawl4AI verbosity (true/false)
CRAWL4AI_VERBOSE=false

# Crawl4AI headless mode (true/false)
CRAWL4AI_HEADLESS=true

# Maximum concurrent Crawl4AI requests
CRAWL4AI_MAX_CONCURRENT=5

# Crawl4AI request timeout (seconds)
CRAWL4AI_TIMEOUT=30

# ----------------------------------------------------------------------------
# OPTIONAL CONFIGURATIONS
# ----------------------------------------------------------------------------
# Data storage path (used inside containers)
DOCS_MCP_STORE_PATH=/data

# PostHog analytics API key (leave empty to disable)
POSTHOG_API_KEY=

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. This file should NOT be committed to version control
# 2. Copy this file to .env and configure with your actual values
# 3. Ensure PostgreSQL has pgvector extension enabled:
#    CREATE EXTENSION IF NOT EXISTS vector;
# 4. Embedding API must be OpenAI-compatible (support /v1/embeddings endpoint)
# 5. Model name must match what your embedding service expects
