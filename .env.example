# Vector Dimension Configuration
# The dimensionality of the embedding vectors stored in the database.
# IMPORTANT: This must match the output dimension of your embedding model.
# Common dimensions:
#   - 1024: text-embedding-3-small (1024d), Google text-embedding-004
#   - 1536: text-embedding-ada-002 (OpenAI legacy)
#   - 3072: text-embedding-3-large
# Default: 1024
VECTOR_DIMENSION=1024

# Embedding Model Configuration
# Optional: Format is "provider:model_name" or just "model_name" for OpenAI (default)
# Examples:
#   - openai:text-embedding-3-small (default if no provider specified)
#   - vertex:text-embedding-004 (Google Cloud Vertex AI)
#   - gemini:gemini-embedding-exp-03-07 (Google Generative AI)
#   - aws:amazon.titan-embed-text-v1
#   - microsoft:text-embedding-ada-002
DOCS_MCP_EMBEDDING_MODEL=

# PostHog Analytics Configuration (Optional)
# Get your API key from: https://app.posthog.com/project/settings
# Leave empty to disable analytics completely
POSTHOG_API_KEY=

# OpenAI Provider Configuration (Default)
# Required for OpenAI provider or as fallback
OPENAI_API_KEY=your-key-here
# Optional: Your OpenAI Organization ID
OPENAI_ORG_ID=
# Optional: Custom base URL for OpenAI-compatible APIs (e.g., Ollama, Azure OpenAI)
OPENAI_API_BASE=

# Google Cloud Vertex AI Configuration
# Required for vertex provider: Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# Google Generative AI (Gemini) Configuration
# Required for gemini provider: Google API key
GOOGLE_API_KEY=your-google-api-key

# AWS Bedrock Configuration
# Required for aws provider
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
# Optional: Use BEDROCK_AWS_REGION instead of AWS_REGION if needed
# BEDROCK_AWS_REGION=us-east-1

# Azure OpenAI Configuration
# Required for microsoft provider
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_API_INSTANCE_NAME=your-instance
AZURE_OPENAI_API_DEPLOYMENT_NAME=your-deployment
AZURE_OPENAI_API_VERSION=2024-02-01

# Optional: Specify a custom directory to store the SQLite database file (documents.db).
# If set, this path takes precedence over the default locations.
# Default behavior (if unset):
# 1. Uses './.store/' in the project root if it exists (legacy).
# 2. Falls back to OS-specific data directory (e.g., ~/Library/Application Support/docs-mcp-server on macOS).
# DOCS_MCP_STORE_PATH=/path/to/your/desired/storage/directory

# Optional: Configure embedding batch limits to prevent "413 Request entity too large" errors
# Maximum characters per embedding batch (default: 50000 ~50KB)
# Lower this if you get 413 errors, increase for better performance if your API supports it
# DOCS_MCP_EMBEDDING_BATCH_CHARS=50000

# ============================================================================
# Rate Limiting Configuration (Issue #80)
# ============================================================================

# Pipeline Concurrency Limits
# Maximum number of scraping jobs to run concurrently (default: 3)
# Increase for faster processing on powerful hardware, decrease for resource-constrained environments
PIPELINE_MAX_CONCURRENCY=3

# Maximum concurrent page requests within a single scraping job (default: 3)
# Controls parallelism when crawling links within a single page
# Higher values may trigger anti-bot measures on target sites
SCRAPER_PAGE_CONCURRENCY=3

# Embedding Rate Limits
# Maximum concurrent image embedding operations (default: 5)
# Controls how many screenshots are processed in parallel
# Adjust based on your embedding API's rate limits and system resources
IMAGE_EMBEDDING_MAX_CONCURRENCY=5

# Maximum documents per embedding batch (default: 100)
# Larger batches improve throughput but may hit API size limits
EMBEDDING_BATCH_SIZE=100

# Network Rate Limits - HTTP Fetcher
# Maximum retry attempts for failed HTTP requests (default: 6)
# Set to 0 to disable retries entirely
HTTP_FETCHER_MAX_RETRIES=6

# Base delay for exponential backoff in milliseconds (default: 1000)
# Delay multiplies by 2^n for each retry attempt (1000ms, 2000ms, 4000ms, etc.)
HTTP_FETCHER_RETRY_DELAY_MS=1000

# Network Rate Limits - Crawl4AI Circuit Breaker
# Number of consecutive failures before opening the circuit (default: 5)
# Circuit breaker prevents cascading failures by temporarily disabling the service
# Increase to tolerate more transient failures, decrease for faster failover
CRAWL4AI_CIRCUIT_BREAKER_THRESHOLD=5

# Time in milliseconds before attempting to reset the circuit breaker (default: 60000)
# After this timeout, the service will attempt to recover if a request succeeds
CRAWL4AI_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# Database Connection Pool Limits
# Minimum number of connections in the pool (default: 2)
# These connections are kept open even when idle
DB_POOL_MIN=2

# Maximum number of connections in the pool (default: 10)
# Increase for higher concurrency, but stay within your database's connection limit
DB_POOL_MAX=10

# Connection timeout in milliseconds (default: 10000)
# How long to wait when establishing a new database connection
DB_CONNECTION_TIMEOUT_MS=10000

# Idle timeout in milliseconds (default: 30000)
# How long to keep idle connections open before closing them
DB_IDLE_TIMEOUT_MS=30000
